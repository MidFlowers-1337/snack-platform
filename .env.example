# ========================================
# 零食电商平台 - Docker 环境变量配置
# 使用方法：复制此文件为 .env 并修改对应值
# ========================================

# MySQL
DB_PASSWORD=your_secure_password
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# 后端
BACKEND_PORT=8080
JWT_SECRET=your-production-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256

# 前端
FRONTEND_PORT=80

# CORS（生产环境改为实际域名）
CORS_ALLOWED_ORIGINS=http://localhost
