<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.snackchain.snack_platform_backend.mapper.OrderItemMapper">

    <!-- 批量查询订单项（解决 N+1 查询问题） -->
    <select id="selectByOrderIds" resultType="com.snackchain.snack_platform_backend.entity.OrderItem">
        SELECT * FROM order_items
        WHERE order_id IN
        <foreach collection="orderIds" item="orderId" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </select>

</mapper>
