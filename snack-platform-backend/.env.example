# ============================================
# 后端环境变量配置示例
# ============================================
# 重要：生产环境必须设置以下环境变量，否则应用将无法启动
# 开发环境可使用 -Dspring.profiles.active=dev 启用开发模式
# ============================================

# 数据库配置 (必需)
DB_URL=jdbc:mysql://localhost:3306/snack_platform?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=your_db_username
DB_PASSWORD=your_secure_password

# JWT配置 (必需) - 生产环境必须设置安全的密钥
# 密钥长度建议至少32字符以上
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-256-bits-long-for-hs256
JWT_EXPIRATION=86400000

# 服务器配置
SERVER_PORT=8080

# Actuator 管理端口 (可选) - 建议生产环境使用独立端口
MANAGEMENT_PORT=8081

# 日志级别
LOG_LEVEL=info
SECURITY_LOG_LEVEL=warn

# MyBatis日志实现
MYBATIS_LOG_IMPL=org.apache.ibatis.logging.slf4j.Slf4jImpl

# CORS配置 - 生产环境应设置为实际前端域名
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# ============================================
# 安全说明
# ============================================
# 1. 生产环境必须设置 DB_URL, DB_USERNAME, DB_PASSWORD, JWT_SECRET
# 2. 不要在代码中硬编码任何敏感信息
# 3. 建议使用密钥管理服务存储敏感配置
# 4. Actuator 端点已限制，仅 /health 和 /info 公开访问
# ============================================